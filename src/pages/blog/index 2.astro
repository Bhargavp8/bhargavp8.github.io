---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../../public/data.json';
const { blogPosts, links } = data;
const livePosts = (blogPosts || []).filter(p => p.title && p.excerpt && p.body?.trim().length > 10);
---
<BaseLayout title="Blog — Bharcode">
  <div class="page-header">
    <div class="section-label">All Posts</div>
    <h1>The Blog</h1>
    <p>Honest documentation of building passive income from code — strategy, tutorials, and what's actually working.</p>
  </div>
  <div class="section" style="padding-top:2rem;">
    <div class="blog-grid">
      {livePosts.map((post, i) => (
        <a href={`/blog/${post.id}`} class={`blog-card reveal ${i % 3 > 0 ? `reveal-delay-${i % 3}` : ''}`}>
          <div class={`blog-thumb ${post.color || 'th-green'}`}>{post.emoji || '📝'}</div>
          <div class="blog-body">
            <div class="blog-tag">{post.category}</div>
            <div class="blog-title">{post.title}</div>
            <div class="blog-excerpt">{post.excerpt}</div>
            <div class="blog-meta">
              <span>{post.date}</span>
              <span class="blog-meta-dot"></span>
              <span>{post.readtime}</span>
            </div>
          </div>
        </a>
      ))}
      <div class="blog-card reveal reveal-delay-3" style="border-style:dashed;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:260px;text-align:center;cursor:default;box-shadow:none;">
        <div style="font-size:1.4rem;margin-bottom:0.7rem;">✍️</div>
        <div style="font-size:0.84rem;color:var(--text3);">More posts coming weekly.<br>Subscribe to stay updated.</div>
        <a href={links.newsletter || '#'} target="_blank" class="btn-primary" style="margin-top:1.1rem;">Subscribe →</a>
      </div>
    </div>
  </div>
</BaseLayout>