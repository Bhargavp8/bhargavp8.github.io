---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../../public/data.json';
const { blogPosts, links } = data;
const livePosts = (blogPosts || []).filter((p: any) => p.title && p.excerpt && p.body?.trim().length > 10);
---
<BaseLayout title="Blog — Bharcode">

  <!-- PAGE HEADER -->
  <div style="max-width:1100px;margin:0 auto;padding:4rem 2rem 0;">
    <div class="section-label">All Posts</div>
    <h1 style="font-family:'DM Serif Display',serif;font-size:clamp(2.8rem,6vw,4.2rem);letter-spacing:-0.04em;line-height:1.0;margin-bottom:1rem;color:var(--text);">
      The Blog
    </h1>
    <p style="font-size:1rem;color:var(--text2);max-width:520px;line-height:1.75;margin-bottom:0;">
      Honest documentation of building passive income from code — strategy, tutorials, and what's actually working.
    </p>

    <!-- Decorative divider -->
    <div style="display:flex;align-items:center;gap:1rem;margin-top:2rem;">
      <div style="flex:1;height:1.5px;background:var(--border);"></div>
      <span style="font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--text3);font-weight:600;white-space:nowrap;">
        {livePosts.length} {livePosts.length === 1 ? 'post' : 'posts'} published
      </span>
      <div style="flex:1;height:1.5px;background:var(--border);"></div>
    </div>
  </div>

  <div class="section" style="padding-top:2.5rem;">

    {livePosts.length === 0 ? (
      <!-- EMPTY STATE -->
      <div style="text-align:center;padding:6rem 2rem;border:1.5px dashed var(--border);border-radius:16px;background:var(--bg-alt);">
        <div style="font-size:3rem;margin-bottom:1rem;">✍️</div>
        <h2 style="font-family:'DM Serif Display',serif;font-size:1.8rem;color:var(--text);margin-bottom:0.5rem;">Nothing here yet.</h2>
        <p style="color:var(--text3);font-size:0.9rem;">First post is on its way. Subscribe to be notified.</p>
        <a href={links?.newsletter || '#'} target="_blank" class="btn-primary" style="margin-top:1.5rem;display:inline-block;">Subscribe →</a>
      </div>
    ) : (
      <div>
        <!-- FEATURED FIRST POST — larger card -->
        {livePosts.length > 0 && (
          <a
            href={`/blog/${livePosts[0].id}`}
            class="blog-featured-card reveal"
            style="text-decoration:none;display:grid;grid-template-columns:1fr 1fr;background:var(--card-bg);border:1.5px solid var(--border);border-radius:16px;overflow:hidden;margin-bottom:2rem;box-shadow:6px 6px 0 var(--accent-light);transition:transform 0.2s,box-shadow 0.2s;"
          >
            <div class={`blog-feat-visual ${livePosts[0].color || 'th-green'}`}>
              <span style="font-size:5rem;">{livePosts[0].emoji || '📝'}</span>
            </div>
            <div style="padding:2.5rem;display:flex;flex-direction:column;justify-content:space-between;">
              <div>
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:1rem;">
                  <span style="font-size:0.67rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--accent);background:var(--bg-alt);border:1px solid var(--border);padding:3px 8px;border-radius:4px;">
                    {livePosts[0].category || 'Post'}
                  </span>
                  <span style="font-size:0.67rem;color:var(--text3);font-weight:600;letter-spacing:0.06em;text-transform:uppercase;">
                    Latest
                  </span>
                </div>
                <h2 style="font-family:'DM Serif Display',serif;font-size:clamp(1.5rem,3vw,2.2rem);color:var(--text);line-height:1.15;letter-spacing:-0.025em;margin-bottom:0.8rem;">
                  {livePosts[0].title}
                </h2>
                <p style="font-size:0.9rem;color:var(--text2);line-height:1.7;">{livePosts[0].excerpt}</p>
              </div>
              <div style="display:flex;align-items:center;justify-content:space-between;margin-top:1.5rem;padding-top:1.2rem;border-top:1.5px solid var(--border);">
                <span style="font-size:0.75rem;color:var(--text3);font-weight:600;">
                  {livePosts[0].date}{livePosts[0].date && livePosts[0].readtime ? ' · ' : ''}{livePosts[0].readtime}
                </span>
                <span style="font-size:0.82rem;color:var(--accent);font-weight:700;">Read →</span>
              </div>
            </div>
          </a>
        )}

        <!-- REST OF POSTS — 3-col grid -->
        {livePosts.length > 1 && (
          <div class="blog-grid">
            {livePosts.slice(1).map((post: any, i: number) => (
              <a
                href={`/blog/${post.id}`}
                class={`blog-card reveal reveal-delay-${Math.min(i + 1, 4)}`}
              >
                <div class={`blog-thumb ${post.color || 'th-green'}`}>{post.emoji || '📝'}</div>
                <div class="blog-body">
                  <div class="blog-tag">{post.category}</div>
                  <div class="blog-title">{post.title}</div>
                  <div class="blog-excerpt">{post.excerpt}</div>
                  <div class="blog-meta">
                    <span>{post.date}</span>
                    {post.date && post.readtime && <span class="blog-meta-dot"></span>}
                    <span>{post.readtime}</span>
                  </div>
                </div>
              </a>
            ))}

            <!-- SUBSCRIBE CARD — always last in the grid -->
            <div
              class="blog-card reveal"
              style="border-style:dashed;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:280px;text-align:center;cursor:default;box-shadow:none;background:var(--bg-alt);"
            >
              <div style="width:48px;height:48px;border-radius:8px;background:var(--card-bg);border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:1.4rem;margin-bottom:1rem;box-shadow:3px 3px 0 var(--accent-light);">✍️</div>
              <p style="font-size:0.84rem;color:var(--text3);line-height:1.6;margin-bottom:1.2rem;max-width:180px;">More posts dropping weekly. Don't miss them.</p>
              <a href={links?.newsletter || '#'} target="_blank" class="btn-primary" style="font-size:0.8rem;padding:0.6rem 1.2rem;">Subscribe →</a>
            </div>
          </div>
        )}

        <!-- If only 1 post, show subscribe below the featured card -->
        {livePosts.length === 1 && (
          <div style="display:flex;align-items:center;gap:1.5rem;padding:1.8rem 2rem;background:var(--bg-alt);border:1.5px solid var(--border);border-radius:12px;box-shadow:4px 4px 0 var(--accent-light);">
            <div style="font-size:2rem;">✍️</div>
            <div style="flex:1;">
              <p style="font-size:0.88rem;font-weight:600;color:var(--text);margin-bottom:0.2rem;">More posts coming weekly.</p>
              <p style="font-size:0.82rem;color:var(--text3);">Subscribe to stay updated.</p>
            </div>
            <a href={links?.newsletter || '#'} target="_blank" class="btn-primary" style="font-size:0.8rem;padding:0.6rem 1.2rem;white-space:nowrap;">Subscribe →</a>
          </div>
        )}
      </div>
    )}

  </div>
</BaseLayout>

<style>
  .blog-featured-card:hover {
    transform: translate(-3px, -3px);
    box-shadow: 9px 9px 0 var(--accent) !important;
  }
  .blog-feat-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 280px;
    border-right: 1.5px solid var(--border);
  }
  @media (max-width: 700px) {
    .blog-featured-card {
      grid-template-columns: 1fr !important;
    }
    .blog-feat-visual {
      min-height: 160px;
      border-right: none !important;
      border-bottom: 1.5px solid var(--border);
    }
  }
</style>