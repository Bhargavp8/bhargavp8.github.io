---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../../public/data.json';
const { blogPosts, links } = data;
const livePosts = (blogPosts || []).filter(p => p.title && p.excerpt && p.body?.trim().length > 10);
---
<BaseLayout title="Blog — Bharcode">
  <div style="max-width:1100px;margin:0 auto;padding:4rem 2rem 0;">
    <div class="section-label">All Posts</div>
    <h1 style="font-family:'DM Serif Display',serif;font-size:clamp(2.8rem,6vw,4.2rem);letter-spacing:-0.04em;line-height:1.0;margin-bottom:1rem;color:var(--text);">
      The Blog
    </h1>
    <p style="font-size:1rem;color:var(--text2);max-width:520px;line-height:1.75;margin-bottom:0;">
      Honest documentation of building passive income from code — strategy, tutorials, and what's actually working.
    </p>
    <div style="display:flex;align-items:center;gap:1rem;margin-top:2rem;">
      <div style="flex:1;height:1.5px;background:var(--border);"></div>
      <span style="font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--text3);font-weight:600;white-space:nowrap;">
        {livePosts.length} {livePosts.length === 1 ? 'post' : 'posts'} published
      </span>
      <div style="flex:1;height:1.5px;background:var(--border);"></div>
    </div>
  </div>

  <div class="section" style="padding-top:2.5rem;">
    {livePosts.length === 0 ? (
      <div style="text-align:center;padding:6rem 2rem;border:1.5px dashed var(--border);border-radius:16px;background:var(--bg-alt);">
        <div style="font-size:3rem;margin-bottom:1rem;">✍️</div>
        <h2 style="font-family:'DM Serif Display',serif;font-size:1.8rem;color:var(--text);margin-bottom:0.5rem;">Nothing here yet.</h2>
        <p style="color:var(--text3);font-size:0.9rem;">First post is on its way. Subscribe to be notified.</p>
        <a href={links?.newsletter || '#'} target="_blank" class="btn-primary" style="margin-top:1.5rem;display:inline-block;">Subscribe →</a>
      </div>
    ) : (
      <div class="blog-grid">
        {livePosts.map((post, i) => (
          <a href={`/blog/${post.id}`} class={`blog-card reveal ${i % 3 > 0 ? `reveal-delay-${i % 3}` : ''}`}>
            <div class={`blog-thumb ${post.color || 'th-green'}`}>{post.emoji || '📝'}</div>
            <div class="blog-body">
              <div class="blog-tag">{post.category}</div>
              <div class="blog-title">{post.title}</div>
              <div class="blog-excerpt">{post.excerpt}</div>
              <div class="blog-meta">
                <span>{post.date}</span>
                {post.date && post.readtime && <span class="blog-meta-dot"></span>}
                <span>{post.readtime}</span>
              </div>
            </div>
          </a>
        ))}
        <div class="blog-card reveal" style="border-style:dashed;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:280px;text-align:center;cursor:default;box-shadow:none;background:var(--bg-alt);">
          <div style="font-size:1.4rem;margin-bottom:0.7rem;">✍️</div>
          <p style="font-size:0.84rem;color:var(--text3);line-height:1.6;margin-bottom:1.2rem;max-width:180px;">More posts dropping weekly. Don't miss them.</p>
          <a href={links?.newsletter || '#'} target="_blank" class="btn-primary" style="font-size:0.8rem;padding:0.6rem 1.2rem;">Subscribe →</a>
        </div>
      </div>
    )}
  </div>
</BaseLayout>
