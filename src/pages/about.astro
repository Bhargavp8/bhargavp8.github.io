---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../../public/data.json';
const { about, costItems, roadmapItems, links, general } = data;
---
<BaseLayout title="About — Bharcode">

  <div style="max-width:1100px;margin:0 auto;padding:4rem 2rem 5rem;">

    <!-- PAGE HEADER -->
    <div style="margin-bottom:3.5rem;">
      <div class="section-label">About</div>
      <h1 style="font-family:'DM Serif Display',serif;font-size:clamp(2.8rem,6vw,4.2rem);letter-spacing:-0.04em;line-height:1.0;color:var(--text);margin-bottom:0;">
        The story so far.
      </h1>
    </div>

    <!-- MAIN CONTENT GRID -->
    <div class="about-layout">

      <!-- LEFT: TEXT -->
      <div class="about-text reveal">
        <h2 set:html={(about?.headline || 'Built by one CS student.\nFor $10 a year.').replace(/\n/g, '<br>')} />

        <p set:html={about?.p1 || "I'm a computer science student in Singapore who got tired of waiting for the right moment to build something."} />
        <p set:html={about?.p2 || '<strong>The answer so far: yes, but it takes compounding.</strong>'} />
        <p set:html={about?.p3 || 'I started by launching a blog on GitHub Pages. Total cost: $10.35 for the domain.'} />
        <p set:html={about?.p4 || '<strong>Why public?</strong> Accountability is free leverage.'} />

        <!-- TECH STACK -->
        <div style="margin-top:2rem;margin-bottom:2rem;">
          <p style="font-size:0.67rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--accent);font-weight:700;margin-bottom:0.8rem;">Stack</p>
          <div class="about-stack">
            {(about?.stack || '⚡ GitHub Pages, 🎨 Canva Free, 🐍 Python').split(',').map((s: string) => (
              <span class="stack-item">{s.trim()}</span>
            ))}
          </div>
        </div>

        <!-- CTAs -->
        <div style="display:flex;gap:0.8rem;flex-wrap:wrap;">
          <a href={links?.cta1 || '#'} target="_blank" rel="noopener noreferrer" class="btn-primary">
            {about?.cta1Text || 'Subscribe'}
          </a>
          <a href={links?.cta2 || '#'} target="_blank" rel="noopener noreferrer" class="btn-outline">
            {about?.cta2Text || 'GitHub'}
          </a>
        </div>
      </div>

      <!-- RIGHT: COST + ROADMAP -->
      <div class="reveal reveal-delay-2">

        <!-- COST BREAKDOWN -->
        <div style="margin-bottom:1.5rem;">
          <p style="font-size:0.67rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--accent);font-weight:700;margin-bottom:1rem;">
            Annual Cost Breakdown
          </p>
          <div class="cost-list">
            {(costItems || []).map((item: any) => (
              <div class={`cost-card${item.isTotal ? ' cost-total' : ''}`}>
                <span class="cost-name" style={item.isTotal ? 'color:var(--accent);' : ''}>
                  {item.name}
                </span>
                <span class={`cost-val${item.isFree ? ' free' : ''}`}>
                  {item.value}
                </span>
              </div>
            ))}
          </div>
        </div>

        <!-- ROADMAP -->
        <div style="background:var(--card-bg);border:1.5px solid var(--border);border-radius:16px;overflow:hidden;box-shadow:5px 5px 0 var(--accent-light);">
          <div style="background:var(--accent);padding:0.9rem 1.4rem;">
            <p style="font-size:0.67rem;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.8);font-weight:700;">The Roadmap</p>
          </div>
          <div style="padding:1.4rem;display:flex;flex-direction:column;gap:0;">
            {(roadmapItems || []).map((item: any, i: number) => (
              <div style={`display:flex;justify-content:space-between;align-items:center;font-size:0.87rem;padding:0.85rem 0;${i < (roadmapItems || []).length - 1 ? 'border-bottom:1px solid var(--border);' : ''}`}>
                <span style="color:var(--text3);font-weight:500;display:flex;align-items:center;gap:8px;">
                  <span style={`width:7px;height:7px;border-radius:50%;border:1.5px solid var(--border);background:${item.accent ? 'var(--accent)' : 'var(--bg-alt)'};flex-shrink:0;`}></span>
                  {item.label}
                </span>
                <span style={`font-weight:700;${item.accent ? 'color:var(--accent);' : 'color:var(--text);'}`}>
                  {item.value}
                </span>
              </div>
            ))}
          </div>
        </div>

        <!-- QUICK STAT CARDS -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.8rem;margin-top:1rem;">
          <div style="background:var(--card-bg);border:1.5px solid var(--border);border-radius:12px;padding:1rem;text-align:center;box-shadow:3px 3px 0 var(--accent-light);">
            <div style="font-family:'DM Serif Display',serif;font-size:2rem;color:var(--text);line-height:1;">$10</div>
            <div style="font-size:0.67rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--text3);font-weight:600;margin-top:4px;">Annual cost</div>
          </div>
          <div style="background:var(--card-bg);border:1.5px solid var(--border);border-radius:12px;padding:1rem;text-align:center;box-shadow:3px 3px 0 var(--accent-light);">
            <div style="font-family:'DM Serif Display',serif;font-size:2rem;color:var(--text);line-height:1;">Day 1</div>
            <div style="font-size:0.67rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--text3);font-weight:600;margin-top:4px;">Building in public</div>
          </div>
        </div>

      </div>
    </div>

    <!-- BOTTOM CTA STRIP -->
    <div style="margin-top:4rem;padding:2.5rem;background:var(--accent);border:1.5px solid var(--border);border-radius:16px;box-shadow:6px 6px 0 var(--border);display:flex;align-items:center;justify-content:space-between;gap:2rem;flex-wrap:wrap;">
      <div>
        <h3 style="font-family:'DM Serif Display',serif;font-size:1.6rem;color:#fff;line-height:1.2;margin-bottom:0.4rem;">
          Follow the journey.
        </h3>
        <p style="font-size:0.88rem;color:rgba(255,255,255,0.75);max-width:380px;line-height:1.6;">
          Weekly updates on what's working, what broke, and what's next. Free forever.
        </p>
      </div>
      <a
        href={links?.cta1 || '#'}
        target="_blank"
        rel="noopener noreferrer"
        style="background:#fff;color:var(--accent);font-family:'DM Sans',sans-serif;font-size:0.88rem;font-weight:700;padding:0.8rem 1.8rem;border-radius:6px;text-decoration:none;border:1.5px solid rgba(255,255,255,0.3);white-space:nowrap;box-shadow:3px 3px 0 rgba(0,0,0,0.15);transition:transform 0.2s,box-shadow 0.2s;display:inline-block;"
        class="about-cta-btn"
      >
        Subscribe Free →
      </a>
    </div>

  </div>
</BaseLayout>

<style>
  .about-cta-btn:hover {
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 rgba(0,0,0,0.2) !important;
  }
</style>