
---
import AdminPanel from '../components/AdminPanel.astro';
import data from '../../public/data.json';
const { general, links } = data;
const { 
  title = "Bharcode — Building Passive Income From Code",
  description = "Built by one CS student. Documenting how I build affiliate income, bots, and tools for the cost of a domain name.",
  ogImage = "https://bharcode.com/assets/logo.png",
  ogUrl = "https://bharcode.com/"
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<link rel="alternate" type="application/rss+xml" title="Bharcode RSS Feed" href="/rss.xml">
<!-- Favicon -->
<link rel="icon" type="image/x-icon" href="/favicon.ico">
<link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png">
<link rel="icon" type="image/png" sizes="512x512" href="/assets/logo.png">
<link rel="apple-touch-icon" href="/assets/logo.png">
<link rel="icon" type="image/webp" sizes="64x64" href="/assets/favicon-64.webp">
<meta name="description" content={description}>
<meta property="og:type" content="website">
<meta property="og:url" content={ogUrl}>
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:image" content={ogImage}>
<meta property="og:image:width" content="512">
<meta property="og:image:height" content="512">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content={ogImage}>

<script is:inline>
  const savedTheme = localStorage.getItem('bharcode-theme');
  const sysDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
  if (savedTheme === 'dark' || (!savedTheme && sysDark)) {
    document.documentElement.setAttribute('data-theme', 'dark');
  }
</script>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">

<style is:global>
  :root {
    --bg: #FBF9F6;
    --bg-alt: #F8F5EE;
    --text: #1C1C1C;
    --text2: #3a3a3a;
    --text3: #6b6b6b;
    --accent: #1A3056;
    --accent-light: rgba(26, 48, 86, 0.1);
    --accent-alt: #203A64;
    --border: #1C1C1C;
    --card-bg: #FFFFFF;
    --card-border: #1C1C1C;
    --tag-bg: rgba(26, 48, 86, 0.08);
    --tag-text: #1A3056;
    --nav-bg: rgba(251, 249, 246, 0.93);
    --ease: cubic-bezier(0.16,1,0.3,1);
  }
  [data-theme="dark"] {
    --bg: #1C1C1C;
    --bg-alt: #262626;
    --text: #FBF9F6;
    --text2: #e0ddd6;
    --text3: #9a9a95;
    --accent: #6B95D6;
    --accent-light: rgba(107, 149, 214, 0.15);
    --accent-alt: #4A76B8;
    --border: #FBF9F6;
    --card-bg: #242424;
    --card-border: #FBF9F6;
    --tag-bg: rgba(251, 249, 246, 0.1);
    --tag-text: #FBF9F6;
    --nav-bg: rgba(28, 28, 28, 0.93);
  }
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);transition:background 0.5s var(--ease),color 0.5s var(--ease);overflow-x:hidden;width:100%;line-height:1.6;cursor:crosshair}
  .cursor-plus{position:fixed;pointer-events:none;z-index:9999;font-size:22px;font-weight:300;color:var(--accent);opacity:0;transform:translate(-50%,-50%) scale(0.4);transition:opacity 0.15s,transform 0.15s;user-select:none;line-height:1}
  .cursor-plus.show{opacity:1;transform:translate(-50%,-50%) scale(1)}
  .cursor-plus.hovering {
    transform: translate(-50%, -50%) scale(1.5); /* Make it bigger */
    color: var(--accent-alt); /* Slightly change color */
    font-weight: 600;
  }
  nav{position:fixed;top:0;left:0;right:0;z-index:100;background:var(--nav-bg);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1.5px solid var(--border);transition:background 0.5s var(--ease),border-color 0.5s var(--ease)}
  .nav-inner{max-width:1100px;margin:0 auto;padding:0 2rem;height:58px;display:flex;align-items:center;justify-content:space-between}
  nav .logo {
  font-family: 'DM Serif Display', serif;
  font-size: 1.3rem;
  color: var(--text);
  text-decoration: none;
  letter-spacing: -0.02em;
  display: flex;
  align-items: center;
  gap: 10px;
  }
  nav .logo-icon {
  width: 28px;
  height: 28px;
  flex-shrink: 0;
  }
  nav .logo-icon img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  }
  .logo-accent{color:var(--accent)}
  .nav-links{display:flex;align-items:center;gap:0.15rem;list-style:none}
  .nav-links a{text-decoration:none;font-family:'DM Sans',sans-serif;font-size:0.85rem;font-weight:500;color:var(--text3);padding:0.4rem 0.9rem;border-radius:4px;transition:color 0.2s,background 0.2s}
  .nav-links a:hover{color:var(--text);background:var(--tag-bg)}
  .nav-links a.active{color:var(--text);background:var(--tag-bg);font-weight:600;border:1.5px solid var(--border);box-shadow:2px 2px 0 var(--accent-light)}
  .toggle-wrap{display:flex;align-items:center;gap:8px}
  .toggle-label{font-size:0.72rem;color:var(--text3);letter-spacing:0.04em;text-transform:uppercase}
  .toggle{position:relative;width:40px;height:22px;cursor:pointer}
  .toggle input{opacity:0;width:0;height:0}
  .toggle-track{position:absolute;inset:0;background:var(--bg);border:1.5px solid var(--border);border-radius:100px}
  .toggle input:checked + .toggle-track{background:var(--accent)}
  .toggle-thumb{position:absolute;top:2px;left:2px;width:14px;height:14px;border-radius:50%;background:var(--border);transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1)}
  [data-theme="dark"] .toggle-thumb{background:#FBF9F6}
  .toggle input:checked ~ .toggle-thumb{transform:translateX(18px);background:var(--bg)}
  .page{min-height:100vh;padding-top:58px}
  .section{max-width:1100px;margin:0 auto;padding:4rem 2rem}
  .section-label{font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--accent);font-weight:600;margin-bottom:0.5rem}
  @keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.4;transform:scale(0.7)}}

  /* BUTTONS — single source of truth, no overrides needed */
  .btn-primary{
    padding:0.7rem 1.6rem;
    background:var(--accent);
    color:#FFFFFF;
    font-family:'DM Sans',sans-serif;
    font-size:0.88rem;
    font-weight:600;
    border:1.5px solid var(--border);
    border-radius:6px;
    cursor:pointer;
    text-decoration:none;
    transition:transform 0.2s,box-shadow 0.2s;
    display:inline-block;
    box-shadow:4px 4px 0 var(--border);
  }
  .btn-primary:hover{transform:translate(-2px,-2px);box-shadow:6px 6px 0 var(--border);color:#FFFFFF}
  .btn-outline{
    padding:0.7rem 1.6rem;
    background:var(--card-bg);
    color:var(--text);
    font-family:'DM Sans',sans-serif;
    font-size:0.88rem;
    font-weight:600;
    border:1.5px solid var(--border);
    border-radius:6px;
    cursor:pointer;
    text-decoration:none;
    transition:transform 0.2s,box-shadow 0.2s;
    display:inline-block;
    box-shadow:4px 4px 0 var(--accent-light);
  }
  .btn-outline:hover{transform:translate(-2px,-2px);box-shadow:6px 6px 0 var(--accent);color:var(--text)}

  .hero{max-width:1100px;margin:0 auto;padding:5rem 2rem 3rem;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;min-height:calc(100vh - 58px)}
  .hero-eyebrow{display:inline-flex;align-items:center;gap:8px;font-size:0.78rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--accent);margin-bottom:1.4rem}
  .hero-dot{width:6px;height:6px;border-radius:50%;background:var(--accent);animation:pulse 2s infinite}
  .hero h1{font-family:'DM Serif Display',serif;font-size:clamp(2.8rem,5.5vw,4.8rem);line-height:1.0;letter-spacing:-0.03em;color:var(--text);margin-bottom:1.4rem}
  .hero h1 em{font-style:italic;color:var(--accent)}
  .hero-sub{font-size:1.05rem;font-weight:400;color:var(--text2);line-height:1.75;margin-bottom:2rem;max-width:420px}
  .hero-actions{display:flex;align-items:center;gap:0.9rem;margin-bottom:2.5rem;flex-wrap:wrap}
  .hero-stats{display:flex;gap:2.5rem;padding-top:2rem;border-top:1.5px solid var(--border)}
  .stat-num{font-family:'DM Serif Display',serif;font-size:1.8rem;color:var(--text);line-height:1}
  .stat-label{font-size:0.72rem;color:var(--text3);margin-top:4px;letter-spacing:0.04em;text-transform:uppercase;font-weight:600}
  .pin-preview-stack{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .pin-card{background:var(--card-bg);border:1.5px solid var(--border);border-radius:8px;overflow:hidden;transition:transform 0.2s,box-shadow 0.2s;text-decoration:none;display:block;cursor:pointer;box-shadow:4px 4px 0 var(--accent-light)}
  .pin-card:hover{transform:translate(-3px,-3px);box-shadow:7px 7px 0 var(--accent)}
  .pin-thumb{height:86px;display:flex;align-items:center;justify-content:center;font-size:1.6rem;border-bottom:1.5px solid var(--border)}
  .th-green{background:#1A3056;color:#FFF}
  .th-teal{background:#203A64;color:#FFF}
  .th-navy{background:#1C1C1C;color:#FFF}
  .th-olive{background:#2a4b82;color:#FFF}
  .th-purple{background:#3a3a3a;color:#FFF}
  .pin-info{padding:11px}
  .pin-title{font-size:0.77rem;font-weight:600;color:var(--text);line-height:1.35;margin-bottom:3px}
  .pin-meta{font-size:0.67rem;color:var(--text3)}
  .pin-card.wide{grid-column:span 2;display:flex;flex-direction:row}
  .pin-card.wide .pin-thumb{min-width:80px;width:80px;height:auto;border-bottom:none;border-right:1.5px solid var(--border);border-radius:0;flex-shrink:0}
  .pin-card.wide .pin-info{flex:1;display:flex;flex-direction:column;justify-content:center}
  .featured-card{background:var(--card-bg);border:1.5px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:1.2rem;transition:transform 0.2s,box-shadow 0.2s;cursor:pointer;box-shadow:5px 5px 0 var(--accent-light)}
  .featured-card:hover{transform:translate(-3px,-3px);box-shadow:8px 8px 0 var(--accent)}
  .featured-inner{display:grid;grid-template-columns:1fr 1fr;min-height:280px}
  .featured-content{padding:2.4rem;display:flex;flex-direction:column;justify-content:space-between}
  .featured-visual{background:var(--bg-alt);display:flex;align-items:center;justify-content:center;border-left:1.5px solid var(--border)}
  .featured-link{font-size:0.82rem;color:var(--accent);font-weight:600;text-decoration:none;margin-top:1.4rem;display:inline-flex;align-items:center;gap:4px}
  .featured-link:hover{color:var(--accent-alt)}
  .project-card{background:var(--card-bg);border:1.5px solid var(--border);border-radius:12px;padding:1.8rem;transition:transform 0.2s,box-shadow 0.2s;cursor:pointer;position:relative;overflow:hidden;box-shadow:5px 5px 0 var(--accent-light)}
  .project-card:hover{transform:translate(-3px,-3px);box-shadow:8px 8px 0 var(--accent)}
  .card-status{display:inline-flex;align-items:center;gap:5px;font-size:0.67rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;padding:3px 10px;border-radius:4px;margin-bottom:0.9rem;border:1.5px solid var(--border)}
.status-live{
  background:var(--accent-light);
  color:var(--accent);
}
.status-building{
  background:rgba(200, 140, 60, 0.12);
  color:#b87d2c;
}
[data-theme="dark"] .status-live{
  background:rgba(107, 149, 214, 0.18);
  color:#7aa5e0;
}
[data-theme="dark"] .status-building{
  background:rgba(220, 170, 80, 0.15);
  color:#e0b04f;
}  .status-soon{background:var(--bg-alt);color:var(--text3)}
  .status-dot{width:5px;height:5px;border-radius:50%;background:currentColor}
  .status-live .status-dot{animation:pulse 2s infinite}
  .card-title{font-family:'DM Serif Display',serif;font-size:1.18rem;color:var(--text);letter-spacing:-0.02em;margin-bottom:0.5rem;line-height:1.25}
  .card-desc{font-size:0.84rem;color:var(--text2);line-height:1.65;margin-bottom:1.2rem}
  .card-tags{display:flex;flex-wrap:wrap;gap:5px}
  .tag{font-size:0.67rem;padding:3px 9px;border-radius:4px;background:var(--bg-alt);color:var(--text);border:1px solid var(--border)}
  .card-arrow{position:absolute;bottom:1.5rem;right:1.5rem;font-size:1rem;color:var(--text3);transition:transform 0.3s,color 0.3s}
  .project-card:hover .card-arrow{transform:translate(3px,-3px);color:var(--accent)}
  .vis-bot{width:200px;border-radius:8px;overflow:hidden;box-shadow:4px 4px 0 var(--border);border:1.5px solid var(--border);animation:floatBot 4s ease-in-out infinite}
  @keyframes floatBot{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
  .vis-bot-bar{background:var(--border);color:var(--bg);padding:9px 12px;display:flex;align-items:center;gap:7px;font-size:0.69rem;font-weight:600}
  .vis-bot-body{background:var(--card-bg);padding:10px;display:flex;flex-direction:column;gap:7px}
  .vis-msg{padding:7px 10px;border-radius:6px;font-size:0.69rem;line-height:1.5;max-width:88%;border:1.5px solid var(--border)}
  .vis-msg.user{background:var(--accent);color:#FFF;align-self:flex-end}
  .vis-msg.bot{background:var(--bg-alt);color:var(--text)}
  .about-layout{display:grid;grid-template-columns:1fr 1.2fr;gap:5rem;align-items:start}
  .about-text h2{font-family:'DM Serif Display',serif;font-size:clamp(2rem,4vw,2.8rem);letter-spacing:-0.025em;line-height:1.1;color:var(--text);margin-bottom:1.2rem}
  .about-text p{font-size:0.94rem;color:var(--text2);line-height:1.8;margin-bottom:1rem;font-weight:400}
  .about-text p strong{color:var(--text);font-weight:600}
  .about-stack{display:flex;flex-wrap:wrap;gap:7px;margin-top:1.5rem;margin-bottom:1.8rem}
  .stack-item{font-size:0.79rem;color:var(--text);background:var(--bg-alt);padding:5px 11px;border-radius:4px;border:1.5px solid var(--border)}
  .cost-list{display:flex;flex-direction:column;gap:9px}
  .cost-card{background:var(--card-bg);border:1.5px solid var(--border);border-radius:8px;padding:0.9rem 1.2rem;display:flex;align-items:center;justify-content:space-between;box-shadow:3px 3px 0 var(--accent-light)}
  .cost-name{font-size:0.84rem;color:var(--text);font-weight:600}
  .cost-val{font-size:0.84rem;font-weight:600}
  .cost-val.free{color:var(--accent)}
  .cost-total{border-color:var(--border);background:var(--accent-light);box-shadow:3px 3px 0 var(--accent)}
  .page-header{padding:3.5rem 2rem 0;max-width:1100px;margin:0 auto}
  .page-header h1{font-family:'DM Serif Display',serif;font-size:clamp(2.2rem,5vw,3.6rem);letter-spacing:-0.03em;line-height:1.05;margin-bottom:0.8rem}
  .page-header p{font-size:1rem;color:var(--text2);font-weight:400;max-width:500px;line-height:1.7}

  /* REVEAL — FIX: was never initialised in Astro, now handled by script below */
  .reveal{opacity:0;transform:translateY(20px);transition:opacity 0.6s var(--ease),transform 0.6s var(--ease)}
  .reveal.visible{opacity:1;transform:translateY(0)}
  .reveal-delay-1{transition-delay:0.08s}
  .reveal-delay-2{transition-delay:0.16s}
  .reveal-delay-3{transition-delay:0.24s}
  .reveal-delay-4{transition-delay:0.32s}

  footer{border-top:1.5px solid var(--border);margin-top:1rem}
  .footer-inner{max-width:1100px;margin:0 auto;padding:1.4rem 2rem;display:flex;align-items:center;justify-content:space-between}
  .footer-left{font-size:0.77rem;color:var(--text2)}
  .footer-left strong{color:var(--text);font-weight:600}
  .footer-right{display:flex;gap:1.4rem}
  .footer-right a{font-size:0.75rem;color:var(--text2);font-weight:600;text-decoration:none;transition:color 0.2s}
  .footer-right a:hover{color:var(--accent)}
  .blog-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.2rem}
  .blog-card{background:var(--card-bg);border:1.5px solid var(--border);border-radius:12px;overflow:hidden;text-decoration:none;display:block;transition:transform 0.2s,box-shadow 0.2s;cursor:pointer;box-shadow:5px 5px 0 var(--accent-light)}
  .blog-card:hover{transform:translate(-3px,-3px);box-shadow:8px 8px 0 var(--accent)}
  .blog-thumb{height:160px;display:flex;align-items:center;justify-content:center;font-size:2.4rem;border-bottom:1.5px solid var(--border)}
  .blog-body{padding:1.3rem}
  .blog-tag{display:inline-block;font-size:0.67rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--accent);margin-bottom:0.6rem;background:var(--bg-alt);border:1px solid var(--border);padding:2px 6px;border-radius:4px}
  .blog-title{font-family:'DM Serif Display',serif;font-size:1.15rem;color:var(--text);line-height:1.25;letter-spacing:-0.02em;margin-bottom:0.45rem}
  .blog-excerpt{font-size:0.82rem;color:var(--text2);line-height:1.6;margin-bottom:0.9rem}
  .blog-meta{display:flex;align-items:center;gap:7px;font-size:0.7rem;color:var(--text3);font-weight:500}
  .blog-meta-dot{width:3px;height:3px;border-radius:50%;background:var(--text3)}
  .blogpost-back{display:inline-flex;align-items:center;gap:6px;font-size:0.82rem;color:var(--text2);font-weight:600;cursor:pointer;border:1.5px solid var(--border);border-radius:4px;background:var(--card-bg);font-family:'DM Sans',sans-serif;padding:0.4rem 0.8rem;transition:all 0.2s;margin-bottom:1.5rem;box-shadow:2px 2px 0 var(--accent-light);text-decoration:none}
  .blogpost-back:hover{transform:translate(-1px,-1px);box-shadow:3px 3px 0 var(--accent)}
  .blogpost-header{margin-bottom:2.5rem}
  .blogpost-category{display:inline-block;font-size:0.7rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--accent);font-weight:600;margin-bottom:0.8rem;border:1.5px solid var(--border);padding:3px 8px;border-radius:4px;background:var(--bg-alt)}
  .blogpost-title{font-family:'DM Serif Display',serif;font-size:clamp(2rem,5vw,3.5rem);line-height:1.1;letter-spacing:-0.03em;color:var(--text);margin-bottom:1rem}
  .blogpost-meta{display:flex;align-items:center;gap:10px;font-size:0.78rem;color:var(--text3);margin-bottom:2rem;font-weight:600}
  .blogpost-hero{width:100%;height:340px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:5rem;margin-bottom:2.5rem;border:1.5px solid var(--border);box-shadow:6px 6px 0 var(--accent-light)}
  .blogpost-body{max-width:680px}
  .blogpost-body h2{font-family:'DM Serif Display',serif;font-size:1.7rem;letter-spacing:-0.02em;line-height:1.2;color:var(--text);margin:2rem 0 0.8rem}
  .blogpost-body h3{font-family:'DM Serif Display',serif;font-size:1.25rem;color:var(--text);margin:1.5rem 0 0.6rem}
  .blogpost-body p{font-size:0.97rem;color:var(--text2);line-height:1.8;margin-bottom:1.2rem;font-weight:400}
  .blogpost-body strong{color:var(--text);font-weight:700}
  .blogpost-body ul,.blogpost-body ol{padding-left:1.4rem;margin-bottom:1.2rem}
  .blogpost-body li{font-size:0.97rem;color:var(--text2);line-height:1.8;font-weight:400;margin-bottom:0.3rem}

  /* ADMIN STYLES */
  #admin-overlay{display:none;position:fixed;inset:0;z-index:200;background:rgba(28,28,28,0.7);backdrop-filter:blur(6px)}
  #admin-overlay.open{display:flex;align-items:stretch}
  #admin-panel{width:100%;max-width:860px;margin:auto;background:var(--bg);border-radius:12px;overflow:hidden;display:flex;flex-direction:column;max-height:90vh;border:1.5px solid var(--border);box-shadow:12px 12px 0 var(--accent)}
  .admin-topbar{display:flex;align-items:center;justify-content:space-between;padding:1.2rem 1.6rem;border-bottom:1.5px solid var(--border);flex-shrink:0;background:var(--card-bg)}
  .admin-topbar h2{font-family:'DM Serif Display',serif;font-size:1.25rem;color:var(--text)}
  .admin-topbar-right{display:flex;align-items:center;gap:10px}
  .admin-close{background:none;border:1.5px solid var(--border);border-radius:4px;font-size:1.2rem;cursor:pointer;color:var(--text);transition:all 0.2s;padding:2px 8px;box-shadow:2px 2px 0 var(--border)}
  .admin-close:hover{transform:translate(-1px,-1px);box-shadow:3px 3px 0 var(--accent)}
  .admin-tabs{display:flex;gap:6px;padding:0.8rem 1.6rem;border-bottom:1.5px solid var(--border);flex-shrink:0;overflow-x:auto;background:var(--card-bg)}
  .admin-tab{background:none;border:1.5px solid transparent;font-family:'DM Sans',sans-serif;font-size:0.82rem;color:var(--text2);cursor:pointer;padding:0.4rem 1rem;border-radius:4px;transition:all 0.2s;white-space:nowrap;font-weight:600}
  .admin-tab.active{background:var(--accent);color:#FFF;border-color:var(--border);box-shadow:2px 2px 0 var(--border)}
  .admin-body{overflow-y:auto;flex:1;padding:1.6rem}
  .admin-section{display:none}
  .admin-section.active{display:block}
  .admin-label{font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--text);font-weight:700;margin-bottom:0.4rem;margin-top:1.2rem}
  .admin-label:first-child{margin-top:0}
  .admin-input,.admin-textarea,.admin-select{width:100%;background:var(--card-bg);border:1.5px solid var(--border);border-radius:6px;padding:0.6rem 0.9rem;font-family:'DM Sans',sans-serif;font-size:0.87rem;color:var(--text);transition:border-color 0.2s;outline:none;box-shadow:inset 2px 2px 0 rgba(0,0,0,0.03)}
  .admin-input:focus,.admin-textarea:focus,.admin-select:focus{border-color:var(--accent);box-shadow:2px 2px 0 var(--accent-light)}
  .admin-textarea{min-height:100px;resize:vertical;line-height:1.6}
  .admin-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
  .admin-btn{display:inline-flex;align-items:center;gap:6px;padding:0.55rem 1.2rem;background:var(--accent);color:#fff;border:1.5px solid var(--border);border-radius:6px;font-family:'DM Sans',sans-serif;font-size:0.82rem;font-weight:600;cursor:pointer;transition:transform 0.2s,box-shadow 0.2s;box-shadow:3px 3px 0 var(--border)}
  .admin-btn:hover{transform:translate(-1px,-1px);box-shadow:4px 4px 0 var(--border)}
  .admin-btn.secondary{background:var(--card-bg);color:var(--text);box-shadow:3px 3px 0 var(--accent-light)}
  .admin-btn.secondary:hover{box-shadow:4px 4px 0 var(--accent)}
  .admin-divider{border:none;border-top:1.5px solid var(--border);margin:1.5rem 0}
  .admin-card-list{display:flex;flex-direction:column;gap:10px;margin-bottom:1.2rem}
  .admin-item{background:var(--card-bg);border:1.5px solid var(--border);border-radius:8px;padding:0.8rem 1rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;box-shadow:3px 3px 0 var(--accent-light)}
  .admin-item-info{flex:1;min-width:0}
  .admin-item-title{font-size:0.85rem;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .admin-item-sub{font-size:0.72rem;color:var(--text3);margin-top:2px;font-weight:500}
  .admin-item-actions{display:flex;gap:6px;flex-shrink:0}
  .admin-icon-btn{background:var(--bg);border:1.5px solid var(--border);border-radius:4px;padding:4px 8px;cursor:pointer;font-size:0.78rem;color:var(--text);transition:all 0.2s;font-family:'DM Sans',sans-serif;font-weight:600;box-shadow:2px 2px 0 var(--accent-light)}
  .admin-icon-btn:hover{transform:translate(-1px,-1px);box-shadow:3px 3px 0 var(--accent)}
  .admin-icon-btn.del:hover{color:#c0392b}
  .admin-notice{background:var(--bg-alt);border:1.5px solid var(--border);border-radius:6px;padding:0.7rem 1rem;font-size:0.82rem;color:var(--text);font-weight:500;margin-bottom:1.2rem;box-shadow:3px 3px 0 var(--accent-light)}
  .admin-notice.warn{border-color:#c88c3c;background:rgba(200,140,60,0.07);color:#8a5f1e}
  .admin-save-bar{padding:1rem 1.6rem;border-top:1.5px solid var(--border);display:flex;justify-content:flex-end;gap:10px;flex-shrink:0;background:var(--card-bg)}
  .admin-color-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:0.5rem}
  .color-opt{width:30px;height:30px;border-radius:4px;cursor:pointer;border:1.5px solid var(--border);transition:transform 0.2s,box-shadow 0.2s;box-shadow:2px 2px 0 var(--accent-light)}
  .color-opt:hover,.color-opt.selected{transform:translate(-2px,-2px);box-shadow:4px 4px 0 var(--accent)}
  #admin-trigger{position:fixed;bottom:1.5rem;right:1.5rem;z-index:150;width:48px;height:48px;border-radius:8px;background:var(--card-bg);color:var(--text);border:1.5px solid var(--border);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1.2rem;box-shadow:4px 4px 0 var(--accent);transition:transform 0.2s,box-shadow 0.2s}
  #admin-trigger:hover{transform:translate(-2px,-2px);box-shadow:6px 6px 0 var(--accent-alt)}
  #admin-login{position:fixed;inset:0;z-index:300;background:rgba(28,28,28,0.7);backdrop-filter:blur(8px);display:none;align-items:center;justify-content:center}
  #admin-login.open{display:flex}
  .login-box{background:var(--bg);border:1.5px solid var(--border);border-radius:12px;padding:2.5rem 2rem;width:340px;text-align:center;box-shadow:8px 8px 0 var(--accent)}
  .login-box h3{font-family:'DM Serif Display',serif;font-size:1.6rem;color:var(--text);margin-bottom:0.6rem}
  .login-box p{font-size:0.86rem;color:var(--text2);margin-bottom:1.5rem;font-weight:500}
  .login-error{font-size:0.78rem;color:#c0392b;margin-top:0.5rem;display:none;font-weight:600}

  @media(max-width:900px){
    .hero{grid-template-columns:1fr;gap:2.5rem;min-height:auto;padding:3rem 1.5rem 2.5rem}
    .featured-inner{grid-template-columns:1fr}
    .featured-visual{min-height:180px;border-left:none;border-top:1.5px solid var(--border)}
    .about-layout{grid-template-columns:1fr;gap:2.5rem}
    .home-two-col{grid-template-columns:1fr !important}
    .admin-row{grid-template-columns:1fr}
  }
@media(max-width:600px){
  .nav-links a{padding:0.4rem 0.5rem;font-size:0.76rem}
  .section{padding:2.5rem 1.5rem}
  .page-header{padding:2.5rem 1.5rem 0}
  .hero-stats{gap:1.5rem}
  #admin-panel{max-height:95vh;border-radius:12px 12px 0 0;margin:auto auto 0;box-shadow:0 -8px 24px rgba(0,0,0,0.2)}
  
  /* Touch-friendly tap targets */
  .nav-links a,
  .btn-primary,
  .btn-outline,
  .admin-tab,
  .admin-icon-btn {
    min-height: 44px;
    min-width: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  
  .toggle {
    width: 50px;
    height: 28px;
  }
  
  .toggle-thumb {
    width: 20px;
    height: 20px;
  }
  
  input, select, textarea {
    font-size: 16px;
  }
  
  #admin-panel {
    width: 100%;
    max-width: 100%;
    margin: 0;
    max-height: 85vh;
  }
  
  .admin-body {
    padding: 1rem;
  }
  
  .admin-tabs {
    flex-wrap: wrap;
    padding: 0.5rem;
  }
  
  .admin-tab {
    font-size: 0.7rem;
    padding: 0.3rem 0.6rem;
  }
  
  .admin-row {
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }
  
  #admin-trigger {
    bottom: 1rem;
    right: 1rem;
    width: 56px;
    height: 56px;
  }
  
  .project-card {
    padding: 1.2rem;
  }
  
  .card-arrow {
    bottom: 1rem;
    right: 1rem;
  }
  
  .vis-bot {
    width: 160px;
  }
  
  .vis-msg {
    font-size: 0.6rem;
    padding: 5px 8px;
  }
  
  .featured-content {
    padding: 1.5rem;
  }
  
  .footer-inner {
    flex-direction: column;
    gap: 0.75rem;
    text-align: center;
  }
}

/* Hide custom cursor on touch devices */
@media (hover: none) and (pointer: coarse) {
  body {
    cursor: default;
  }
  
  .cursor-plus {
    display: none !important;
  }
}

/* iPhone notch safe area */
@supports (padding: max(0px)) {
  nav {
    padding-left: max(1rem, env(safe-area-inset-left));
    padding-right: max(1rem, env(safe-area-inset-right));
  }
  
  body {
    padding-bottom: env(safe-area-inset-bottom);
  }
}
</style>
</head>
<body>
<div class="cursor-plus" id="cursor-plus">+</div>

<nav>
  <div class="nav-inner">
    <a href="/" class="logo">
        <span class="logo-icon">
            <picture>
                <source srcset="/assets/logo.webp" type="image/webp">
                <img src="/assets/logo.png" alt="Bharcode Logo">
            </picture>
        </span>
        <span><span class="logo-accent">Bhar</span>code</span>
    </a>
    <ul class="nav-links">
      <li><a href="/" class:list={[{ active: Astro.url.pathname === '/' }]}>Home</a></li>
      <li><a href="/blog" class:list={[{ active: Astro.url.pathname.startsWith('/blog') }]}>Blog</a></li>
      <li><a href="/apps" class:list={[{ active: Astro.url.pathname === '/apps' }]}>Apps</a></li>
      <li><a href="/about" class:list={[{ active: Astro.url.pathname === '/about' }]}>About</a></li>
    </ul>
    <div class="toggle-wrap">
      <span class="toggle-label" id="theme-label">Light</span>
      <label class="toggle">
        <input type="checkbox" id="theme-toggle">
        <div class="toggle-track"></div>
        <div class="toggle-thumb"></div>
      </label>
    </div>
  </div>
</nav>

<main style="min-height:100vh;padding-top:58px">
  <slot />
</main>

<footer>
  <div class="footer-inner">
    <div class="footer-left">© {general.footerYear || '2026'} <strong>{general.sitename || 'Bharcode'}</strong> · {general.footerTagline || 'Singapore · Built for $10'}</div>
    <div class="footer-right">
      <a href={links.github || '#'} target="_blank">GitHub</a>
      <a href={links.pinterest || '#'} target="_blank">Pinterest</a>
      <a href={links.newsletter || '#'} target="_blank">Newsletter</a>
    </div>
  </div>
</footer>

<AdminPanel />

<script is:inline>
  // Updated Cursor Plus Logic
  const cursorEl = document.getElementById('cursor-plus');
  
  document.addEventListener('mousemove', e => {
    cursorEl.style.left = e.clientX + 'px';
    cursorEl.style.top = e.clientY + 'px';
    cursorEl.classList.add('show');

    // Check if the element under the cursor is clickable
    const target = e.target;
    const isClickable = target.closest('a, button, .toggle, input, .pin-card, .featured-card, .blog-card');
    
    if (isClickable) {
      cursorEl.classList.add('hovering');
      cursorEl.innerText = '○'; // Change from + to a circle (or '↗')
    } else {
      cursorEl.classList.remove('hovering');
      cursorEl.innerText = '+'; // Back to plus
    }
  });

  document.addEventListener('mouseleave', () => cursorEl.classList.remove('show'));
  // Theme Toggle
  const toggle = document.getElementById('theme-toggle');
  const label = document.getElementById('theme-label');
  const html = document.documentElement;

  function applyTheme(theme) {
    html.setAttribute('data-theme', theme);
    if (toggle) toggle.checked = (theme === 'dark');
    if (label) label.textContent = theme === 'dark' ? 'Dark' : 'Light';
  }

  const saved = localStorage.getItem('bharcode-theme');
  if (saved) applyTheme(saved);

  toggle?.addEventListener('change', () => {
    const t = toggle.checked ? 'dark' : 'light';
    applyTheme(t);
    localStorage.setItem('bharcode-theme', t);
  });

  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', e => {
    if (!localStorage.getItem('bharcode-theme')) applyTheme(e.matches ? 'dark' : 'light');
  });

  // FIX: Scroll reveal — was never initialised in the Astro version.
  // .reveal elements were permanently stuck at opacity:0.
  // Now runs on every page load via BaseLayout.
  function initReveal() {
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -20px 0px' });
    document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initReveal);
  } else {
    initReveal();
  }
</script>
</body>
</html>
